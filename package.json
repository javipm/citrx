{
  "name": "citrx",
  "version": "0.1.0",
  "description": "CLI for local-first Apache/Nginx access log analysis.",
  "type": "module",
  "packageManager": "pnpm@11.1.0",
  "bin": {
    "citrx": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_ES.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "update-bot-ranges": "tsx scripts/update-bot-ranges.ts",
    "prepack": "pnpm run build"
  },
  "keywords": [
    "apache",
    "nginx",
    "access-log",
    "security",
    "cli",
    "forensics",
    "openai",
    "tui"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=24.15"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "ink": "^7.0.3",
    "openai": "^6.10.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.6",
    "tar-stream": "^3.2.0",
    "yauzl": "^3.3.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.15",
    "@types/tar-stream": "^3.1.4",
    "@types/yauzl": "^2.10.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
